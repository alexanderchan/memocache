{
	"name": "@alexmchan/memocache-store-libsql",
	"version": "1.0.0",
	"private": false,
	"dependencies": {
		"@libsql/client": "^0.17.0",
		"superjson": "^2.2.6",
		"@alexmchan/memocache-common": "workspace:^"
	},
	"devDependencies": {
		"@alexmchan/memocache": "workspace:^",
		"@arethetypeswrong/cli": "^0.18.2",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3",
		"vite-tsconfig-paths": "^6.1.1",
		"@vitest/coverage-v8": "^4.1.0",
		"vitest": "^4.1.0"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/alexmchan/memocache"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"scripts": {
		"build": "tsup",
		"check-exports": "pnpm pack --out ./ignore-package.tgz && pnpm exec attw ./ignore-package.tgz && rm ./ignore-package.tgz",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"coverage": "vitest run --coverage",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"test:watch": "vitest --watch"
	},
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"default": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	}
}
