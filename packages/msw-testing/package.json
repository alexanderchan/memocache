{
	"name": "@alexmchan/msw-testing",
	"version": "2.0.1",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"default": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"scripts": {
		"build": "tsup-node",
		"build:watch": "pnpm run build --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"lint": "biome check .",
		"lint:fix": "biome check --write ."
	},
	"repository": {
		"url": "git@github.com/alexanderchan/memocache.git"
	},
	"peerDependencies": {
		"msw": ">=2.0.0",
		"prettier": ">=3.0.0"
	},
	"devDependencies": {
		"msw": "^2.12.10",
		"prettier": "^3.8.1",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.1.0"
	}
}
