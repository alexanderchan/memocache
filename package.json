{
  "name": "cache",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "prepare": "husky",
    "ci": "turbo run ci",
    "test:ci": "pnpm run ci",
    "build": "turbo build",
    "test": "turbo run test",
    "lint:staged": "lint-staged",
    "docs": "pnpm run --filter '*docs' dev",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "turbo run typecheck",
    "release:view": "gh pr list --app github-actions --web",
    "release:pr": "tsx ./scripts/merge-changeset-pr.ts",
    "release:local": "pnpm run build && changeset version && changeset publish",
    "release": "pnpm run build && pnpm release:local && git push --follow-tags",
    "lint": "turbo run lint",
    "test:coverage": "turbo run coverage"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@changesets/cli": "^2.30.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@commander-js/extra-typings": "^14.0.0",
    "commander": "^14.0.3",
    "@inquirer/prompts": "^8.3.0",
    "@types/node": "^25.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "tsx": "^4.21.0",
    "turbo": "^2.8.17",
    "zx": "^8.8.5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "packageManager": "pnpm@10.32.1"
}
